{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "components/*": ["./components/*"],
      "hooks/*": ["./hooks/*"]
    }
  },
  "include": [
    "App.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "svg.d.ts"
  ],
  "exclude": ["app", "components", "dist", "node_modules"]
}
